generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  avatarUrl      String?
  oidcSub        String?  @unique
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id])
  memberships    Membership[]
  aiRuns         AiRun[]
  auditLogs      AuditLog[]
  approvals      ApprovalRequest[]

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  companies Company[]
  settings  AppSettings?
  diagrams  Diagram[]

  @@map("organizations")
}

// ─── Settings ──────────────────────────────────────────────────────────────────

model AppSettings {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  llmProvider     String   @default("anthropic") // "anthropic" | "openai"
  llmModel        String   @default("claude-sonnet-4-6")
  anthropicApiKey String?
  openaiApiKey    String?
  voyageApiKey    String?

  // AI tuning
  embeddingModel  String   @default("voyage-3-lite")
  chunkSize       Int      @default(800)
  chunkOverlap    Int      @default(100)
  retrievalTopK   Int      @default(5)
  temperature     Float    @default(0.3)
  maxTokens       Int      @default(4096)

  // Organization / locale
  timezone        String   @default("UTC")
  dateFormat      String   @default("medium")
  defaultTheme    String   @default("dark")

  // Grouped toggles
  approvals       Json?    // { createTicket, sendMessage, updateDoc, publishDiagram }
  notifications   Json?    // { inApp, email, urgentRecs, approvals, atRisk }

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("app_settings")
}

// ─── Hierarchy ────────────────────────────────────────────────────────────────

model Company {
  id                 String   @id @default(cuid())
  organizationId     String
  name               String
  description        String?
  website            String?
  logoKey            String?
  complianceProfile  ComplianceProfile? @relation(fields: [complianceProfileId], references: [id])
  complianceProfileId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id])
  programs      Program[]
  projects      Project[]
  members       Member[]

  @@map("companies")
}

model Program {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projects  Project[]

  @@map("programs")
}

model Project {
  id                  String        @id @default(cuid())
  organizationId      String
  companyId           String
  programId           String?
  name                String
  description         String?
  status              ProjectStatus @default(ACTIVE)
  startDate           DateTime?
  targetEndDate       DateTime?
  complianceProfile   ComplianceProfile? @relation(fields: [complianceProfileId], references: [id])
  complianceProfileId String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  program       Program?      @relation(fields: [programId], references: [id], onDelete: SetNull)
  workstreams   Workstream[]
  memberships   Membership[]
  members       Member[]
  milestones    Milestone[]
  risks         Risk[]
  transcripts   MeetingTranscript[]
  knowledgeItems KnowledgeItem[]
  recommendations Recommendation[]
  aiRuns        AiRun[]
  diagrams      Diagram[]
  agentRuns     AgentRun[]
  integrations  ProjectIntegration[]

  @@map("projects")
}

model Workstream {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("workstreams")
}

enum ProjectStatus {
  ACTIVE
  AT_RISK
  ON_HOLD
  COMPLETED
  ARCHIVED
}

// ─── People ───────────────────────────────────────────────────────────────────

model Membership {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String   @default("member")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("memberships")
}

model Member {
  id           String   @id @default(cuid())
  companyId    String?
  projectId    String?
  managerId    String?
  affiliationId String?
  jobRoleId    String?
  orgUnitId    String?
  name         String
  email        String?
  notes        String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  manager Member?  @relation("MemberReports", fields: [managerId], references: [id], onDelete: SetNull)
  reports Member[] @relation("MemberReports")
  affiliation Affiliation? @relation(fields: [affiliationId], references: [id], onDelete: SetNull)
  jobRole     JobRole?     @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  orgUnit     OrgUnit?     @relation(fields: [orgUnitId], references: [id], onDelete: SetNull)

  @@map("members")
}

// ─── Member lookups (DB-managed master data) ──────────────────────────────────

model Affiliation {
  id        String   @id @default(cuid())
  label     String   @unique
  color     String   @default("#64748b")
  createdAt DateTime @default(now())

  members Member[]

  @@map("affiliations")
}

model JobRole {
  id        String   @id @default(cuid())
  label     String   @unique
  createdAt DateTime @default(now())

  members Member[]

  @@map("job_roles")
}

model OrgUnit {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  members Member[]

  @@map("org_units")
}

// ─── Planning ─────────────────────────────────────────────────────────────────

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  dueDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Risk {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  severity    String   @default("medium")
  status      String   @default("open")
  mitigationPlan String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("risks")
}

// ─── Transcripts & Knowledge ──────────────────────────────────────────────────

model MeetingTranscript {
  id             String   @id @default(cuid())
  projectId      String
  title          String
  rawContent     String
  storageKey     String?
  occurredAt     DateTime?
  classification DataClassification @default(INTERNAL)
  processedAt    DateTime?
  source         String   @default("manual") // manual | granola | …
  externalId     String?  // provider's id (e.g. Granola note id) for dedupe
  metadata       Json?    // provider metadata: attendees, organiser, times, web_url, …
  createdAt      DateTime @default(now())

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  knowledgeItems KnowledgeItem[]

  @@unique([projectId, source, externalId])
  @@map("meeting_transcripts")
}

// ─── Integrations (connectors) ─────────────────────────────────────────────

/// Org-level connection to an external provider (e.g. Granola). One per provider.
model Integration {
  id             String   @id @default(cuid())
  organizationId String
  provider       String   // granola | jira | slack | …
  name           String
  credentials    Json     // { apiKey: "grn_…" } — masked on read
  status         String   @default("connected") // connected | error | disconnected
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectLinks ProjectIntegration[]

  @@unique([organizationId, provider])
  @@map("integrations")
}

/// Per-project link to a connection + the scope rules that map items to the project.
model ProjectIntegration {
  id             String    @id @default(cuid())
  projectId      String
  integrationId  String
  provider       String
  enabled        Boolean   @default(true)
  scope          Json      @default("{}") // { mode, keywords[], ownerDomains[], folderIds[], noteIds[] }
  lastSyncedAt   DateTime?
  lastSyncStatus String?
  lastSyncCount  Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([projectId, integrationId])
  @@map("project_integrations")
}

model KnowledgeItem {
  id             String   @id @default(cuid())
  projectId      String
  transcriptId   String?
  sourceType     String
  title          String
  content        String
  classification DataClassification @default(INTERNAL)
  createdAt      DateTime @default(now())

  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transcript MeetingTranscript? @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  chunks     KnowledgeChunk[]

  @@map("knowledge_items")
}

model KnowledgeChunk {
  id              String   @id @default(cuid())
  knowledgeItemId String
  content         String
  chunkIndex      Int
  embedding       Unsupported("vector(512)")?
  createdAt       DateTime @default(now())

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  @@map("knowledge_chunks")
}

enum DataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  PII
  PHI
  FINANCIAL
  LEGAL
}

// ─── AI & Recommendations ─────────────────────────────────────────────────────

model AiRun {
  id           String   @id @default(cuid())
  projectId    String?
  userId       String
  agentType    String
  promptVersion String
  inputSummary String?
  outputJson   Json?
  modelId      String?
  createdAt    DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  recommendations Recommendation[]

  @@map("ai_runs")
}

model Recommendation {
  id          String             @id @default(cuid())
  projectId   String
  aiRunId     String?
  type        String
  title       String
  description String?
  payload     Json?
  status      RecommendationStatus @default(PENDING)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  aiRun    AiRun?           @relation(fields: [aiRunId], references: [id], onDelete: SetNull)
  approval ApprovalRequest?

  @@map("recommendations")
}

model ApprovalRequest {
  id               String         @id @default(cuid())
  recommendationId String         @unique
  requestedById    String
  status           ApprovalStatus @default(PENDING)
  reviewedAt       DateTime?
  reviewNote       String?
  createdAt        DateTime       @default(now())

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  requestedBy    User           @relation(fields: [requestedById], references: [id])

  @@map("approval_requests")
}

enum RecommendationStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  DISMISSED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Compliance ───────────────────────────────────────────────────────────────

model ComplianceProfile {
  id                String   @id @default(cuid())
  name              String
  hipaaEnabled      Boolean  @default(false)
  piaRequired       Boolean  @default(false)
  phiHandling       String   @default("none")
  retentionDays     Int?
  auditLevel        String   @default("standard")
  aiAccessPolicy    String   @default("allow")
  allowedExports    String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  companies Company[]
  projects  Project[]

  @@map("compliance_profiles")
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── Diagrams ─────────────────────────────────────────────────────────────────

model Diagram {
  id             String   @id @default(cuid())
  projectId      String?
  organizationId String?
  title          String
  description    String?
  kind           String   @default("architecture")
  schemaJson     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  versions     DiagramVersion[]

  @@map("diagrams")
}

// ─── AI Skills platform ────────────────────────────────────────────────────

/// A capability the AI agent can invoke as a tool. Managed from the dashboard.
model Skill {
  id             String   @id @default(cuid())
  organizationId String?  // null = built-in / global
  slug           String   @unique // tool name exposed to the model (snake_case)
  name           String
  description    String   // the tool description the model reads to decide when to call
  instructions   String?  // extra guidance appended to the system prompt when enabled
  kind           String   @default("action") // action | composite | prompt
  handlerKey     String?  // action skills: which coded handler executes it
  inputSchema    Json     // JSON Schema for the tool input
  composes       String[] @default([]) // composite skills: slugs it may orchestrate
  externalAction Boolean  @default(false) // true → routes through the approval queue
  enabled        Boolean  @default(true)
  model          String?  // optional model override
  version        Int      @default(1)
  builtin        Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("skills")
}

/// One agent invocation — the unit shown in the dashboard's run inspector.
model AgentRun {
  id             String   @id @default(cuid())
  projectId      String?
  organizationId String
  userId         String   @default("user_dev")
  surface        String   // ask | transcript | skill-generator | …
  goal           String   // the user's request / trigger
  status         String   @default("running") // running | completed | failed | awaiting_approval
  answer         String?
  model          String?
  tokensIn       Int      @default(0)
  tokensOut      Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  steps   AgentStep[]

  @@map("agent_runs")
}

/// A single step in an agent run — thinking, tool call, tool result, text, error.
model AgentStep {
  id        String   @id @default(cuid())
  runId     String
  idx       Int
  type      String   // thinking | text | tool_call | tool_result | error
  skillSlug String?
  title     String?
  content   Json?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@map("agent_steps")
}

model DiagramVersion {
  id         String   @id @default(cuid())
  diagramId  String
  version    Int
  schemaJson Json
  createdAt  DateTime @default(now())

  diagram Diagram @relation(fields: [diagramId], references: [id], onDelete: Cascade)

  @@map("diagram_versions")
}
