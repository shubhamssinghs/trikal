# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trikal:your_password@localhost:5432/trikal
DATABASE_URL_READONLY=postgresql://trikal_ro:your_password@localhost:5432/trikal

POSTGRES_USER=trikal
POSTGRES_PASSWORD=your_password
POSTGRES_DB=trikal

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=trikal
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=trikal

# ─── Auth / OIDC ──────────────────────────────────────────────────────────────
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=trikal
OIDC_CLIENT_SECRET=your_client_secret
JWT_SECRET=your_jwt_secret_min_32_chars

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=4000
WEB_URL=http://localhost:3000

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
