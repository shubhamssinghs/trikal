# Trikal — Environment Configuration
# Copy this file to .env and adjust values

# ===== Ports (follow X310 pattern) =====
FRONTEND_PORT=4310
BACKEND_PORT=8310
POSTGRES_PORT=5310
REDIS_PORT=6310
QDRANT_HTTP_PORT=7310
QDRANT_GRPC_PORT=7311
NGINX_PORT=9310

# ===== PostgreSQL =====
POSTGRES_USER=trikal
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=trikal_db

# ===== Backend Secrets =====
BACKEND_SECRET_KEY=change-me-to-a-random-string
BACKEND_ENVIRONMENT=development

# ===== Redis =====
# No extra config needed for dev — uses container name

# ===== Qdrant =====
# Uncomment when ready to use vector DB
# QDRANT_URL=http://qdrant:6333
