# Trikal Backend — Environment Configuration
# Copy to .env and adjust values

# Database
DATABASE_URL=postgresql+asyncpg://trikal:change-me@postgres:5432/trikal_db

# Redis
REDIS_URL=redis://redis:6379

# Qdrant (uncomment when ready)
# QDRANT_URL=http://qdrant:6333

# Application
SECRET_KEY=change-me-to-a-random-string
ENVIRONMENT=development

# CORS
CORS_ORIGINS=["http://localhost:4310"]

# OpenID Connect (Trishul IAM)
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_AUDIENCE=your-audience-id
OIDC_REDIRECT_URI=http://localhost:8310/api/v1/auth/callback
FRONTEND_URL=http://localhost:4310/auth/callback
FRONTEND_LOGOUT_URL=http://localhost:4310/login
